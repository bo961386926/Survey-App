# ========================================
# Survey-App 环境变量配置
# 使用说明：复制此文件为 .env 并修改相应配置
# ========================================

# ========================================
# 数据库配置
# ========================================
DB_ROOT_PASSWORD=root
DB_NAME=survey_db
DB_USERNAME=survey_user
DB_PASSWORD=survey_password
DB_MAX_CONNECTIONS=200
DB_BUFFER_POOL=256M

# ========================================
# Redis 配置
# ========================================
REDIS_PASSWORD=redis_password
REDIS_MAX_MEMORY=128mb

# ========================================
# JWT 配置
# 生产环境必须修改为强密钥！
# ========================================
JWT_SECRET=survey-jwt-secret-key-change-in-production-2026
JWT_EXPIRATION=7200000
JWT_REFRESH_EXPIRATION=604800000

# ========================================
# 应用配置
# ========================================
APP_ENV=prod
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000,http://localhost:9527,http://localhost:9528

# ========================================
# 端口映射（如需修改默认端口）
# ========================================
# MYSQL_PORT=3306
# REDIS_PORT=6379
# BACKEND_PORT=8081
