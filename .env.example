# ========================================
# Survey-App 环境变量配置
# 使用说明：复制此文件为 .env 并修改相应配置
# ========================================

# ========================================
# 数据库配置
# ========================================
DB_ROOT_PASSWORD=root
DB_NAME=survey_db
DB_USERNAME=survey_user
DB_PASSWORD=survey_password

# ========================================
# Redis 配置
# ========================================
REDIS_PASSWORD=redis_password

# ========================================
# JWT 配置
# 生产环境必须修改为强密钥！
# ========================================
JWT_SECRET=survey-jwt-secret-key-change-in-production-2026

# ========================================
# 应用配置
# ========================================
APP_ENV=prod
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000
